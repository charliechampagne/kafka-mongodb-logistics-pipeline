# =============================================================================
# Confluent Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=<your-cluster>.gcp.confluent.cloud:9092
KAFKA_SASL_USERNAME=<your-kafka-api-key>
KAFKA_SASL_PASSWORD=<your-kafka-api-secret>
KAFKA_TOPIC=delivery_trip_truck

# =============================================================================
# Confluent Schema Registry Configuration
# =============================================================================
SCHEMA_REGISTRY_URL=https://<your-schema-registry-id>.gcp.confluent.cloud
SCHEMA_REGISTRY_API_KEY=<your-schema-registry-api-key>
SCHEMA_REGISTRY_API_SECRET=<your-schema-registry-api-secret>
SCHEMA_SUBJECT=delivery_trip_truck-value

# =============================================================================
# MongoDB Atlas Configuration
# =============================================================================
MONGO_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster-name>.<id>.mongodb.net/?appName=<app-name>
MONGO_DATABASE=Showreel
MONGO_COLLECTION=delivery_trip_truck

# =============================================================================
# Kafka Consumer Configuration
# =============================================================================
KAFKA_CONSUMER_GROUP_ID=logistics-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000